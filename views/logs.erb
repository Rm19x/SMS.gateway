<h1>Riwayat Pengiriman</h1>
<table>
    <tr>
        <th>Nomor</th>
        <th>Status</th>
        <th>Gateway</th>
        <th>Waktu</th>
    </tr>
    <% @logs.each do |log| %>
    <tr>
        <td><%= log.phone_number %></td>
        <td><%= log.status %></td>
        <td><%= log.gateway_used %></td>
        <td><%= log.created_at %></td>
    </tr>
    <% end %>
</table>
